extends ../layout

block content
  .d-flex.justify-content-between.align-items-center.mb-4.p-4.rounded-3(style='background: linear-gradient(135deg, #4f46e5, #7c3aed); color: white;')
    div
      h4.fw-semibold.mb-1 Returned Assets
      p.small.mb-0 View all returned asset records
    a.btn.btn-light.text-dark.fw-semibold.px-3(href='/returnAsset/add') + Return Asset

  .card.border-0.shadow-sm
    .card-body.p-0
      table#returnTable.table.table-hover.table-bordered.align-middle.mb-0
        thead.table-primary
          tr
            th #
            th Employee
            th Asset Code
            th Make
            th Model
            th Issue Date
            th Return Date
            th Reason
            th Status

        tbody
          each item, index in returnedAssets
            tr
              td= index + 1
              td.fw-medium= item.Employee.name
              td= item.Asset.assetCode
              td= item.Asset.make
              td= item.Asset.model
              td= item.issueDate
              td= item.returnDate
              td= item.reason
              td
                if item.status === 'RETURNED'
                  span.badge.bg-success.px-3.py-2 Returned
                else
                  span.badge.bg-warning.text-dark.px-3.py-2 Issued

block scripts
  script.
    $(document).ready(function () {
      $('#returnTable').DataTable();
    });