extends ../layout

block content
  .d-flex.justify-content-between.align-items-center.mb-4.p-4.rounded-3(style='background: linear-gradient(135deg, #4f46e5, #7c3aed); color: white;')
    div
      h4.fw-semibold.mb-1 Asset Category List
      p.small.mb-0 Manage your asset categories and their status
    a.btn.btn-light.text-dark.fw-semibold.px-3(href='/asset-category/add') + Add Category

  .card.border-0.shadow-sm
    .card-body.p-0
      table#categoryTable.table.table-hover.table-bordered.align-middle.mb-0
        thead.table-primary
          tr
            th Category Name
            th Status
            th.text-center Actions
        tbody
          each category in categoryData
            tr
              td.fw-medium= category.name
              td
                if category.status
                  span.badge.bg-success.px-3.py-2 Active
                else
                  span.badge.bg-danger.px-3.py-2 Inactive
              td.text-center
                a.btn.btn-warning.btn-sm.me-2(href=`/asset-category/edit/${category.id}`) Edit
                a.btn.btn-danger.btn-sm(href=`/asset-category/delete/${category.id}` onclick="return confirm('Are you sure?')") Delete

block scripts
  script.
    $(document).ready(function () {
      $('#categoryTable').DataTable();
    });