extends ../layout

block content

  .d-flex.justify-content-between.align-items-center.mb-4
    div
      h2.fw-bold.mb-1 Issued Assets
      p.text-muted.mb-0 View all asset issue records
    a.btn.btn-primary(href="/issue")
      i.bi.bi-plus-circle.me-2
      | Issue Asset

  .card.border-0.shadow-sm
    .card-body

      table.table.table-hover.align-middle#issueTable
        thead.table-dark
          tr
            th #
            th Employee
            th Asset Code
            th Manufacturer
            th Model
            th Issue Date
            th Status

        tbody

          each issue, index in issues
            tr
              td= index + 1
              td= issue.Employee.name
              td= issue.Asset.assetCode
              td= issue.Asset.manufacturer
              td= issue.Asset.model
              td= issue.issueDate

              td
                if issue.status === "ISSUED"
                  span.badge.bg-warning.text-dark Issued
                else
                  span.badge.bg-success Returned

script.
  $(document).ready(function () {
      $('#issueTable').DataTable();
  });