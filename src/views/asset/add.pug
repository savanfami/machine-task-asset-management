extends ../layout

block content
  .p-4.mb-4.rounded-3(style='background: linear-gradient(135deg, #4f46e5, #7c3aed); color: white;')
    h2.mb-1.fw-bold Add Asset
    p.mb-0.small Enter asset information

  .card.border-0.shadow-sm
    .card-body.p-4

      form(action='/assets/add', method='POST')

        .mb-3
          label.form-label.fw-semibold Asset Code
          input.form-control(type='text', name='assetCode', required)

        .mb-3
          label.form-label.fw-semibold Serial Number
          input.form-control(type='text', name='serialNumber', required)

        .mb-3
          label.form-label.fw-semibold Manufacturer
          input.form-control(type='text', name='manufacturer', required)

        .mb-3
          label.form-label.fw-semibold Model
          input.form-control(type='text', name='model', required)

        .mb-3
          label.form-label.fw-semibold Purchase Cost
          input.form-control(type='number', name='purchaseCost', required)

        .mb-3
          label.form-label.fw-semibold Purchase Date
          input.form-control(type='date', name='purchaseDate')

        .mb-3
          label.form-label.fw-semibold Category

          select.form-select(name='categoryId', required)
            option(value='') Select Category
            each category in categories
              option(value=category.id)= category.name

        .mb-4
          label.form-label.fw-semibold Status

          select.form-select(name='status')
            option(value='IN_STOCK') In Stock
            option(value='ISSUED') Issued
            option(value='DAMAGED') Damaged

        .d-flex.gap-2
          button.btn.btn-success.px-4(type='submit') Save Asset
          a.btn.btn-outline-secondary.px-4(href='/assets') Cancel