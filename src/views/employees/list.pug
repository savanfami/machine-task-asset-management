extends ../layout

block content
  .d-flex.justify-content-between.align-items-center.mb-3
    h2 Employee List
    a.btn.btn-primary(href='/employees/add') Add Employee

  table#employeeTable.table.table-striped.table-bordered
    thead
      tr
        th Name
        th Email
        th Branch
        th Status
        th Actions
    tbody
      each employee in employeeInfo
        tr
          td= employee.name
          td= employee.email
          td= employee.branch
          td
            if employee.status
              span.badge.bg-success Active
            else
              span.badge.bg-danger Inactive
          td
            a.btn.btn-warning.btn-sm.me-2(href=`/employees/edit/${employee.id}`) Edit
            a.btn.btn-danger.btn-sm(href=`/employees/delete/${employee.id}` onclick="return confirm('Are you sure?')") Delete

block scripts
  script.
    $(document).ready(function () {
      $('#employeeTable').DataTable();
    });