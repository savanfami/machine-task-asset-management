extends ../layout

block content
  .d-flex.justify-content-between.align-items-center.mb-4.p-4.rounded-3(style='background: linear-gradient(135deg, #4f46e5, #7c3aed); color: white;')
    div
      h4.fw-semibold.mb-1 Employee List
      p.small.mb-0 Manage your team members and their status
    a.btn.btn-light.text-dark.fw-semibold.px-3(href='/employees/add') + Add Employee

  .card.border-0.shadow-sm
    .card-body.p-0
      table#employeeTable.table.table-hover.table-bordered.align-middle.mb-0
        thead.table-primary
          tr
            th Name
            th Email
            th Branch
            th Status
            th.text-center Actions
        tbody
          each employee in employeeInfo
            tr
              td.fw-medium= employee.name
              td.text-muted= employee.email
              td= employee.branch
              td
                if employee.status
                  span.badge.bg-success.px-3.py-2 Active
                else
                  span.badge.bg-danger.px-3.py-2 Inactive
              td.text-center
                a.btn.btn-warning.btn-sm.me-2(href=`/employees/edit/${employee.id}`) Edit
                a.btn.btn-danger.btn-sm(href=`/employees/delete/${employee.id}` onclick="return confirm('Are you sure?')") Delete

block scripts
  script.
    $(document).ready(function () {
      $('#employeeTable').DataTable();
    });