extends ../layout

block content
  //- Colored page header
  .p-4.mb-4.rounded-3(style='background: linear-gradient(135deg, #4f46e5, #7c3aed); color: white;')
    h2.mb-1.fw-bold Add Employee
    p.mb-0.small Enter employee details and assign their status

  //- Form card
  .card.border-0.shadow-sm
    .card-body.p-4
      form(action='/employees/add', method='POST')
        .mb-3
          label.form-label.fw-semibold Name
          input.form-control(type='text', name='name', required)

        .mb-3
          label.form-label.fw-semibold Email
          input.form-control(type='email', name='email', required)

        .mb-3
          label.form-label.fw-semibold Branch
          input.form-control(type='text', name='branch', required)

        .mb-4
          label.form-label.fw-semibold Status
          select.form-select(name='status')
            option(value='true') Active
            option(value='false') Inactive

        .d-flex.gap-2
          button.btn.btn-success.px-4(type='submit') Save Employee
          a.btn.btn-outline-secondary.px-4(href='/employees') Cancel